# Claude API（小説生成・知見抽出に使用）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 使用するClaudeモデル（省略時は settings/model_config.json の値を使用）
# CLAUDE_MODEL=claude-sonnet-4-6

# LINE Messaging API（生成完了通知に使用）
# ※ LINE Notify は2025年3月31日にサービス終了したため LINE Messaging API を使用
# チャンネルアクセストークン（LINE Developers Console > Messaging API > チャンネルアクセストークン）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
# 通知先ユーザーID（LINE Developers Console > Messaging API > ユーザーID、またはWebhookのsourceから取得）
LINE_USER_ID=your_line_user_id_here
